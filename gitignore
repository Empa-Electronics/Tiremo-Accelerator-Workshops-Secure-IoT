# Eclipse workspace metadata (machine-specific, must NOT be in Git)
**/Workspace/.metadata/

# Auto-generated makefiles (contain absolute paths from the developer's machine)
**/Workspace/**/makefile
**/Workspace/**/objects.mk
**/Workspace/**/sources.mk
**/Workspace/**/subdir.mk

# Compiler-generated dependency files (contain absolute paths)
**/*.d

# Compiled object files
**/*.o

# Build outputs
**/*.elf
**/*.hex
**/*.map
**/*.bin
**/*.lst
